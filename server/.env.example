# ── SupportAI Server — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development             # development | production

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/supportai?retryWrites=true&w=majority

# ── Authentication ────────────────────────────────────────────────────────────
# Use a random 32+ character string. Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_32_plus_random_chars
JWT_EXPIRES_IN=7d

# ── AI ────────────────────────────────────────────────────────────────────────
# Google Gemini API key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Test keys: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in your Stripe dashboard
# Products → Add product → Add price → Copy the price ID (price_xxx)
STRIPE_STARTER_MONTHLY=price_...
STRIPE_STARTER_YEARLY=price_...
STRIPE_PRO_MONTHLY=price_...
STRIPE_PRO_YEARLY=price_...
STRIPE_ENTERPRISE_MONTHLY=price_...
STRIPE_ENTERPRISE_YEARLY=price_...

# ── Cloud Storage (AWS S3 / Cloudflare R2) ────────────────────────────────────
# Leave blank in development to skip cloud storage (PDFs processed in-memory).
# Compatible with AWS S3 and any S3-compatible provider (Cloudflare R2, MinIO).
#
# Cloudflare R2:
#   STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   STORAGE_REGION=auto
#   STORAGE_FORCE_PATH_STYLE=false
#
# AWS S3:
#   STORAGE_ENDPOINT=https://s3.<region>.amazonaws.com
#   STORAGE_REGION=us-east-1
#   STORAGE_FORCE_PATH_STYLE=false
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=<r2-or-iam-access-key>
STORAGE_SECRET_ACCESS_KEY=<r2-or-iam-secret-key>
STORAGE_BUCKET=supportai-documents
STORAGE_REGION=auto
# Public base URL for stored files (R2 custom domain, CloudFront, etc.)
# If omitted, URLs are constructed from STORAGE_ENDPOINT + STORAGE_BUCKET
STORAGE_PUBLIC_URL=https://documents.yourdomain.com
STORAGE_FORCE_PATH_STYLE=false

# ── Frontend ──────────────────────────────────────────────────────────────────
# Used for CORS and Stripe redirect URLs
CLIENT_URL=http://localhost:5173

# ── Email (required for password reset and team invites) ──────────────────────
# Without these, password reset emails will not be sent.
# In development the reset URL is printed to the server console instead.
#
# Recommended providers:
#   Resend    — https://resend.com  (simplest, generous free tier)
#   SendGrid  — SMTP_HOST=smtp.sendgrid.net  SMTP_PORT=587  SMTP_USER=apikey
#   AWS SES   — SMTP_HOST=email-smtp.<region>.amazonaws.com  SMTP_PORT=587
#   Mailgun   — SMTP_HOST=smtp.mailgun.org  SMTP_PORT=587
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_smtp_password_or_api_key
EMAIL_FROM=SupportAI <noreply@yourdomain.com>
